# Servidor
PORT=3001
NODE_ENV=development

# Banco de Dados PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=safebite_db
DB_USER=postgres
DB_PASSWORD=postgres

# JWT - Autenticação
JWT_SECRET=seu_jwt_secret_super_seguro_mude_em_producao_123456789
JWT_EXPIRES_IN=24h

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=seu_email@gmail.com
EMAIL_PASSWORD=sua_senha_de_app
EMAIL_FROM=noreply@safebite.com

# Upload de Arquivos - Storage
# Opções: 'local', 'imgbb', 'imgur'
STORAGE_TYPE=local

# ============================================
# ImgBB (se STORAGE_TYPE=imgbb) - GRATUITO
# ============================================
# Obtenha uma chave gratuita em: https://api.imgbb.com/
# IMGBB_API_KEY=sua_chave_api_imgbb

# ============================================
# Imgur (se STORAGE_TYPE=imgur) - GRATUITO
# ============================================
# Obtenha Client ID em: https://api.imgur.com/oauth2/addclient
# IMGUR_CLIENT_ID=seu_client_id_imgur


# Upload de Arquivos
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg,image/webp

# CORS
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
# Em desenvolvimento, o padrão é 1000 requisições por 15 minutos
# Em produção, o padrão é 100 requisições por 15 minutos
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# URL Base da API
API_BASE_URL=http://localhost:3001

# Frontend URL (para links em emails)
FRONTEND_URL=http://localhost:3000

