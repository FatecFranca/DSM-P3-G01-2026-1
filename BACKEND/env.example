# Servidor
PORT=3001
NODE_ENV=development

# Banco de Dados MongoDB
MONGODB_URI=mongodb://localhost:27017
DB_NAME=safebite_db

# Para usar MongoDB Atlas (nuvem), substitua pela sua connection string:
# MONGODB_URI=mongodb+srv://<usuario>:<senha>@cluster0.xxxxx.mongodb.net

# JWT - Autenticação
JWT_SECRET=seu_jwt_secret_super_seguro_mude_em_producao_123456789
JWT_EXPIRES_IN=24h

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=seu_email@gmail.com
EMAIL_PASSWORD=sua_senha_de_app
EMAIL_FROM=noreply@safebite.com

# Upload de Arquivos - Storage
# Opções: 'local', 'imgbb', 'imgur'
STORAGE_TYPE=local

# ============================================
# ImgBB (se STORAGE_TYPE=imgbb) - GRATUITO
# ============================================
# IMGBB_API_KEY=sua_chave_api_imgbb

# ============================================
# Imgur (se STORAGE_TYPE=imgur) - GRATUITO
# ============================================
# IMGUR_CLIENT_ID=seu_client_id_imgur

# Upload de Arquivos
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg,image/webp

# CORS
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# URL Base da API
API_BASE_URL=http://localhost:3001

# Frontend URL (para links em emails)
FRONTEND_URL=http://localhost:3000
