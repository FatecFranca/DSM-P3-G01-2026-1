# Configuração para ambiente de testes
NODE_ENV=test

# Banco de Dados PostgreSQL (Teste)
DB_HOST=localhost
DB_PORT=5432
DB_TEST_NAME=safebite_test_db
DB_NAME=safebite_test_db
DB_USER=postgres
DB_PASSWORD=postgres

# JWT - Autenticação
JWT_SECRET=test-secret-key-for-jwt-tests-only
JWT_EXPIRES_IN=24h

# Email (Nodemailer) - Pode usar valores de teste
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=test@test.com
EMAIL_PASSWORD=test
EMAIL_FROM=noreply@safebite.com

# CORS
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Storage
STORAGE_TYPE=local

